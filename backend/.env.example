# Copy this file to .env and fill in real values. .env is gitignored.

# PostgreSQL connection
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=synchr

# Port the Go server listens on
PORT=8080

# Secret used to sign/verify JWTs - use a long random string in any real deployment
JWT_SECRET=change_this_to_a_long_random_string
