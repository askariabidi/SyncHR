# Used by docker-compose.yml. Copy to .env and adjust if you want anything
# other than the defaults baked into docker-compose.yml itself.

DB_USER=synchr
DB_PASSWORD=synchr
DB_NAME=synchr
JWT_SECRET=change_this_to_a_long_random_string

# The URL the frontend's static build is compiled to call. Must be reachable
# from the *browser*, not from inside the Docker network - so it's normally
# localhost when running docker-compose on your own machine, or your real
# public backend URL when deployed.
FRONTEND_API_URL=http://localhost:8080/api
